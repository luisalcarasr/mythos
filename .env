# macOS — Homebrew GTK4 runtime paths
# uv reads this file automatically for `uv run` and activated venv sessions.
# Required on macOS because python.org Python does not search /opt/homebrew/lib
# by default. Adjust HOMEBREW_PREFIX if your Homebrew is not at /opt/homebrew.
DYLD_LIBRARY_PATH=/opt/homebrew/lib
GI_TYPELIB_PATH=/opt/homebrew/lib/girepository-1.0
